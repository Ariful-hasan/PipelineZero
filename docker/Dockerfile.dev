FROM node:24-alpine

RUN apk add --no-cache openssl shadow

ARG USER_ID=1000
ARG GROUP_ID=1000
ARG DATABASE_URL

RUN if ! getent group ${GROUP_ID} > /dev/null; then \
        addgroup -g ${GROUP_ID} appgroup; \
    fi && \
    if ! getent passwd ${USER_ID} > /dev/null; then \
        adduser -u ${USER_ID} -G $(getent group ${GROUP_ID} | cut -d: -f1) -D appuser; \
    fi

WORKDIR /app

# Ensure correct permissions for the WORKDIR
RUN chown -R ${USER_ID}:${GROUP_ID} /app

# Switch to the non-root user
USER ${USER_ID}

# Set environment variables
ENV DATABASE_URL=${DATABASE_URL}

# Copy package files first for better caching
COPY --chown=${USER_ID}:${GROUP_ID} package*.json ./
COPY --chown=${USER_ID}:${GROUP_ID} prisma ./prisma/

# Install all dependencies
RUN npm install

# Copy the rest of the application
COPY --chown=${USER_ID}:${GROUP_ID} . .

# Generate Prisma Client
RUN npx prisma generate

# The command is usually overridden in docker-compose for dev
CMD ["npm", "run", "start:dev"]
