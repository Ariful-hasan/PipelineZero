FROM node:24-alpine

RUN apk add --no-cache openssl shadow

ARG USER_ID=1000
ARG GROUP_ID=1000

RUN if ! getent group ${GROUP_ID} > /dev/null; then \
        addgroup -g ${GROUP_ID} appgroup; \
    fi && \
    if ! getent passwd ${USER_ID} > /dev/null; then \
        adduser -u ${USER_ID} -G $(getent group ${GROUP_ID} | cut -d: -f1) -D appuser; \
    fi

WORKDIR /app

# 1. Copy config and package files first (Needed for install and prisma generate)
COPY package*.json prisma.config.ts tsconfig.json ./
COPY prisma ./prisma/

# 2. Install dependencies 
RUN npm install

# 3. Generate Prisma Client (Optimized caching)
RUN DATABASE_URL="postgresql://dummy:dummy@localhost:5432/dummy" npx prisma generate

# 4. Copy the remaining source files 
COPY . .

# 5. Fix ownership permissions and drop down to unprivileged execution context
RUN chown -R ${USER_ID}:${GROUP_ID} /app
USER ${USER_ID}

CMD ["npm", "run", "start:dev"]
