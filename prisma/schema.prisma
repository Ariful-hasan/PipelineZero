// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id              String                @id @default(uuid(7)) @db.Uuid
  name            String                @db.VarChar(255)
  email           String                @unique @db.VarChar(255)
  password        String                @db.VarChar(255)
  isActive        Boolean               @default(true) @map("is_active")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  
  workspaces      WorkspaceUser[]
  invitationsSent WorkspaceInvitation[]
  jobApplications JobApplication[]
  statusChanges   JobStatusHistory[]

  @@map("users")
}

model Workspace {
  id          String          @id @default(uuid(7)) @db.Uuid
  name        String          @db.VarChar(255)
  slug        String          @unique @db.VarChar(255)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  
  users       WorkspaceUser[]
  invitations WorkspaceInvitation[]
  jobApplications JobApplication[]

  @@map("workspaces")
}

model WorkspaceUser {
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@map("workspace_users")
}

model WorkspaceInvitation {
  id          String        @id @default(uuid(7)) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  invitedBy   String        @map("invited_by") @db.Uuid
  email       String        @db.VarChar(255)
  role        WorkspaceRole 
  token       String        @unique @db.VarChar(255)
  status      String        @default("pending") @db.VarChar(50)
  expiresAt   DateTime      @map("expires_at") @db.Timestamp(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender      User          @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@map("workspace_invitations")
}

model JobApplication {
  id              String             @id @default(uuid(7)) @db.Uuid
  workspaceId     String             @map("workspace_id") @db.Uuid
  createdByUserId String             @map("created_by_user_id") @db.Uuid
  company         String             @db.VarChar(255)
  title           String             @db.VarChar(255)
  description     String?            @db.Text
  url             String?            @db.Text
  salaryMin       Int?               @map("salary_min")
  salaryMax       Int?               @map("salary_max")
  currency        String             @default("USD") @db.Char(3)
  location        String?            @db.VarChar(255)
  status          String             @default("applied") @db.VarChar(50)
  appliedAt       DateTime           @default(now()) @map("applied_at") @db.Timestamp(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser   User               @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  statusHistory   JobStatusHistory[]

  @@map("job_applications")
}

model JobStatusHistory {
  id               String         @id @default(uuid(7)) @db.Uuid
  jobApplicationId String         @map("job_application_id") @db.Uuid
  changedByUserId  String         @map("changed_by_user_id") @db.Uuid
  oldStatus        String?        @map("old_status") @db.VarChar(50)
  newStatus        String         @map("new_status") @db.VarChar(50)
  notes            String?        @db.Text
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  changedByUser    User           @relation(fields: [changedByUserId], references: [id], onDelete: Cascade)

  @@map("job_status_history")
}